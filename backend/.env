# PORT=5000
# MONGODB_URI=mongodb://localhost:27017/marketplace
# JWT_SECRET=your_super_secret_key_change_this
# JWT_EXPIRE=7d


# Backend (.env)
NODE_ENV=production
PORT=5000

# Database
DB_HOST=your-production-db-host
DB_PORT=5432
DB_NAME=marketplace
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Redis (for queues/caching)
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRE=30d

# Razorpay [citation:2]
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxx

# Email (SendGrid/Mailgun)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@yourmarketplace.com

# Shipping Carriers API Keys [citation:8]
DELHIVERY_KEY=your_delhivery_key
DTDC_KEY=your_dtdc_key
FEDEX_KEY=your_fedex_key
BLUEDART_KEY=your_bluedart_key

# Frontend URL (for CORS)
FRONTEND_URL=https://yourmarketplace.netlify.app

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
AWS_BUCKET=your-marketplace-bucket